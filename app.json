{
  "expo": {
    "name": "VividCoach",
    "slug": "vividcoach",
    "scheme": "vividcoach",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vividcoach.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e100f"
      },
      "package": "com.vividcoach.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      ["expo-sensors", {
        "motionPermission": "Allow VividCoach to read your step count so your coach can see your daily activity."
      }],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0e100f",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
