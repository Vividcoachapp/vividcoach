{
  "expo": {
    "name": "VividCoach",
    "slug": "vividcoach",
    "scheme": "vividcoach",
    "version": "1.0.0",
    "buildNumber": "1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vividcoach.app",
      "buildNumber": "1",
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      },
      "infoPlist": {
        "NSHealthShareUsageDescription": "VividCoach reads your steps, sleep, calories, and heart rate so your coach has full context without you logging everything manually.",
        "NSHealthUpdateUsageDescription": "VividCoach can write workout data when you log a session."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e100f"
      },
      "package": "com.vividcoach.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-notifications",
      [
        "expo-sensors",
        {
          "motionPermission": "Allow VividCoach to read your step count so your coach can see your daily activity."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow VividCoach to access your camera to scan food barcodes."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0e100f",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
